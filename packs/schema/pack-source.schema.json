{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cockatoo.local/schema/pack-source-v2.json",
  "title": "Cockatoo accepted pack source",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "sourceLanguage", "language", "version", "provenance", "grading", "validation", "items"],
  "properties": {
    "schema": {"const": 2},
    "sourceLanguage": {"$ref": "#/$defs/languageTag"},
    "language": {"$ref": "#/$defs/languageTag"},
    "version": {"type": "string", "minLength": 1},
    "provenance": {
      "type": "object",
      "required": ["corpus", "license", "packtool", "generatedAt"],
      "properties": {
        "corpus": {"type": "string", "minLength": 1},
        "corpusVersion": {"type": ["string", "null"]},
        "corpusURL": {"type": ["string", "null"]},
        "license": {"type": "string", "minLength": 1},
        "packtool": {"type": "string", "minLength": 1},
        "authoringModel": {"type": ["string", "null"]},
        "promptVersion": {"type": ["string", "null"]},
        "inputChecksum": {"type": ["string", "null"]},
        "generatedAt": {"type": "string", "minLength": 1}
      }
    },
    "grading": {
      "type": "object",
      "additionalProperties": false,
      "required": ["articles", "localeIdentifier", "diacriticInsensitive", "substitutions"],
      "properties": {
        "articles": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "localeIdentifier": {"type": "string", "minLength": 1},
        "diacriticInsensitive": {"type": "boolean"},
        "substitutions": {"type": "object", "additionalProperties": {"type": "string"}}
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceDeterminers", "nounPartsOfSpeech", "disallowedAmbientPartsOfSpeech", "allowApproximateAmbient"],
      "properties": {
        "sourceDeterminers": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "nounPartsOfSpeech": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "disallowedAmbientPartsOfSpeech": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "allowApproximateAmbient": {"type": "boolean"}
      }
    },
    "items": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/item"}}
  },
  "$defs": {
    "languageTag": {"type": "string", "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"},
    "sourceForm": {
      "type": "object", "additionalProperties": false, "required": ["form", "target"],
      "properties": {"form": {"type": "string", "minLength": 1}, "target": {"type": "string", "minLength": 1}}
    },
    "example": {
      "type": "object", "additionalProperties": false, "required": ["source", "target"],
      "properties": {"source": {"type": "string", "minLength": 1}, "target": {"type": "string", "minLength": 1}}
    },
    "item": {
      "type": "object",
      "required": ["id", "language", "sourceLemma", "kind", "sourceForms", "target", "level", "frequencyBand", "replacementPolicy", "fidelityTier", "dependencies", "explanation", "examples"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "language": {"$ref": "#/$defs/languageTag"},
        "sourceLemma": {"type": "string", "minLength": 1},
        "kind": {"enum": ["word", "chunk", "pattern"]},
        "sourceForms": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/sourceForm"}},
        "target": {"type": "string", "minLength": 1},
        "targetMeta": {"type": ["object", "null"]},
        "level": {"enum": ["a1", "a2", "b1", "b2", "c1", "c2"]},
        "frequencyBand": {"type": "integer", "minimum": 1, "maximum": 10},
        "replacementPolicy": {"enum": ["ambientSafe", "reviewOnly", "never"]},
        "fidelityTier": {"enum": ["exact", "formMatched", "approximate"]},
        "dependencies": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "explanation": {"type": "string"},
        "examples": {"type": "array", "items": {"$ref": "#/$defs/example"}},
        "anchor": {"type": ["boolean", "null"]}
      }
    }
  }
}
