{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cockatoo.local/schema/pack-review-v1.json",
  "title": "Cockatoo pack review record",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "language", "version", "sourceChecksum", "reviewer", "reviewedAt", "checklist"],
  "properties": {
    "schema": {"const": 1},
    "language": {"type": "string", "pattern": "^[A-Za-z]{2,3}(-[A-Za-z0-9]{2,8})*$"},
    "version": {"type": "string", "minLength": 1},
    "sourceChecksum": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "reviewer": {"type": "string", "minLength": 1},
    "reviewedAt": {"type": "string", "minLength": 1},
    "notes": {"type": ["string", "null"]},
    "checklist": {
      "type": "object",
      "additionalProperties": false,
      "required": ["translations", "sourceForms", "examples", "safety", "licensing"],
      "properties": {
        "translations": {"const": true},
        "sourceForms": {"const": true},
        "examples": {"const": true},
        "safety": {"const": true},
        "licensing": {"const": true}
      }
    }
  }
}
